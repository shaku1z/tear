rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // each player owns their cloud save
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid
        && (!('username' in request.resource.data) ||
            (request.resource.data.username.size() >= 3 &&
             request.resource.data.username.size() <= 16 &&
             request.resource.data.username.matches('^[a-zA-Z0-9 _-]+$') &&
             (resource == null || !('usernameSetAt' in resource.data) || request.time > resource.data.usernameSetAt + duration.value(7, 'd'))));
    }
    // public leaderboards; you may only write/delete your own entry, score must be numeric
    match /leaderboards/{board}/scores/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid
                            && request.resource.data.score is number;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
    // append-only balancing telemetry (developer reads in the console only)
    match /telemetry/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
    // one replay ghost per board (public read, authed write) — legacy, superseded by /replays
    match /ghosts/{board} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // published replays: a RunSummary doc + the recording chunked underneath.
    // Anyone can watch; only the owner (the Replay Passport uid) can create/replace/delete.
    match /replays/{id} {
      allow read: if true;
      allow create, update: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
      match /chunks/{n} {
        allow read: if true;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }
    }
  }
}
